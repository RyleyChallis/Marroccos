@media (max-width: 821px) {
    #story .header h2 {
        max-width: 500px;
        margin: 0 auto;
        align-items: center;
    }
    #story .header h3 {
        max-width: 600px !important;
        text-align: center;
        align-items: center;
    }
    #story .container {
        display: flex !important;
        flex-direction: column !important;
    }


    #reviews .header::after {
        content: none;
        display: none;
    }
    #reviews h2 {
        max-width: 450px;
        text-align: center;
        align-items: center;
        margin: 0 auto;
    }
    body #reviews .container {
        display: flex !important;
        flex-direction: column !important;
        flex-wrap: wrap;
        max-width: 100%;
        gap: 30px;
    }
    #reviews .container .review-list {
        display: flex !important;
        flex-direction: column !important;
        gap: 30px !important;
        flex-wrap: wrap;
        max-width: 750px;

    }
    body #reviews .container .review-item {
        display: flex;
        flex-direction: column;
        width: 450px;
        min-height: 500px;
        text-align: center;
        align-items: center;
    }
    .review-item i {
        padding: 30px;
        padding-bottom: 0;
        padding-right: 0;
    }
    #showcase .container {
        display: flex;
        flex-direction: column !important;
        flex-wrap: wrap;
        max-width: 100%;
    }
    #showcase .showcase-container {
        display: flex !important;
        flex-direction: column !important;
        gap: 30px;
        max-width: 750px;
        position: relative;
    }
    .showcase-container .showcase-item {
         background-color: #fff; 
        box-shadow: 5px 5px 20px rgba(0, 0, 0, 0.2);
        min-height: auto;
        width: 450px !important;
        border-radius: 5px;
        
        display: flex;
        flex-direction: column;
        justify-content: space-between; 
        position: relative; 
        transition: all 0.3s ease;
    }
    .showcase-item img {
        min-width: 100%;
        aspect-ratio: 1 / 1;
        border-radius: 5px 5px 0 0;
        object-fit: cover;
        padding: 0;
    }
    .showcase-caption {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        text-align: left;
        padding: 20px;
        height: 150px;
    }
    .showcase-caption h4 {
        font-size: 26px;
    }
    .showcase-caption p {
        max-width: 390px;
    }
    #location .container {
        display: flex;
        flex-direction: column-reverse;
    }
    #location iframe {
        box-shadow: 5px 5px 30px rgba(0, 0, 0, 0.4);
    }
    #faqs .container {
        max-width: 600px;
        justify-content: center;
        margin: 0 auto;
    }
    #faq-item {
        width: 70%;
    }
    #contact {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;     
        padding: 60px 20px;
        position: relative;
    }
    #contact h2 {
        max-width: 500px;
    }
    #contact .container {
        padding-left: 0 !important; 
        padding-right: 0 !important; 
        width: 100% !important;        
        max-width: none !important; 
    }

    #contact .contact-form {
        width: 90% !important;         
        margin: 0 auto !important;   
        display: flex !important;
        flex-direction: column !important;  
    }
    .contact-form .contact-column-left, .contact-column-right {
        flex: 1;
        width: 100% !important;
        display: flex;
        flex-direction: column;
        align-self: stretch;
    }
    .contact-form .contact-header {
        margin-right: auto;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        align-items: flex-start; 
        width: 100%;
    }
    textarea {
        height: 150px; 
        width: 100% !important;
        border-radius: 4px;
        padding: 10px;
        font-family: inherit;
    }
    .footer-container {
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: wrap;
        max-width: 750px !important;
        margin: 0 auto;
        justify-content: center;
    }
    .footer-container .social-label {
        font-size: 1.2rem;
    }
    .social-icons {
        display: flex;
        justify-content: center;
        margin: 0 auto;
        align-items: center;
    }
    .footer-container .social-icons a {
        font-size: 1.3rem !important;
        padding: 30px;
    }
    .menu-section {
        display: flex;
        flex-direction: column;
        align-items: center; 
        width: 100%;
    }
    .menu-section .header::after {
        display: none;
        content: none
    }
    .menu-section .header {
        text-align: center !important;
        width: 80%;
        margin-top: 0;     
        margin: 0 auto !important;
        padding: 75px 0;
        justify-content: center !important;
    }
    .menu-section .header h3 {
        max-width: 450px !important;
        font-weight: 300; 
        width: 100% !important;
        text-align: center !important;
        margin-left: auto !important;
        margin-right: auto !important;
        display: block !important; 
    }
    .menu-grid {
        display: grid !important;
        grid-template-columns: repeat(2, 1fr) !important;
    }
    .menu-item {
        display: flex;
        flex-direction: column;
        width: 100% !important; 
        max-width: 100% !important; 
        min-width: 0; 
        padding: 0 !important;
        margin: 0 !important;
        background-color: transparent;
        margin-bottom: 25px !important;
    }
    .menu-item img {
        width: 100%;
        height: auto;
        aspect-ratio: 1 / 1;
        border-radius: 5px 5px 0 0;
    }
    .menu-caption {
        border-radius: 0 0 5px 5px;
    }
    #booking .booking-form {
        display: flex;
        flex-direction: column !important;
        align-items: flex-start;
        width: 90%;
        box-shadow: 0 0 30px rgba(0, 0, 0, 0.6);
    }
    .booking-form .booking-column-left, .booking-column-right {
        flex: 1;
        width: 100%;
        align-items: flex-start;
    }
    .booking-summary-display {
        display: flex !important;
        flex-direction: column !important;
        align-items: flex-end !important;
        text-align: right !important;
        width: 100%;
    }
    .book-now-btn {
        background-color: var(--cta-hover) !important;
        color: white !important;
        border-radius: 3px;
        padding: 18px;
        font-family: 'Montserrat', sans-serif;
        letter-spacing: 3px;
        text-transform: uppercase;
        display: flex;
        align-items: center !important;
        width: 100%;
        text-align: center !important;
        justify-content: center;
    }
}
