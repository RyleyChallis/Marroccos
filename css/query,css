



@media (max-width: 1450px) {
    #reviews .container {
        display: flex;
        gap: 15px;
        max-width: 80%;
        margin: 0 auto;
        justify-content: center;
    }
    #reviews .review-item {
        width: 350px;
        min-height: 500px;
        justify-content: center;
    }
    .review-item p {
        font-size: 19px;
    }
    #showcase .container {
        display: flex;
        gap: 15px;
        max-width: 80%;
        margin: 0 auto;
    }
    #showcase .container .showcase-item {
        width: 350px;
        min-height: 470px;
        margin-bottom: 50px;
    }
}

